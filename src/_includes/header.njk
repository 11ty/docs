<aside>
	{% include "components/product-tabs.njk" %}
</aside>
<header class="elv-header{% if headerClass %} {{ headerClass }}{% endif %}">
	<div class="elv-menu">
		<ul class="elv-nav-menu list-bare fl fl-inline fl-nowrap">
			<li><a href="/docs/">Get Started</a></li>
			<li><a href="/pro/"><span class="elv-header-pro">Pro</span></a></li>
			<li><a href="/blog/">Blog</a></li>
			<li><a href="/docs/community/">Community</a></li>
			{# <li><a href="/docs/versions/"><code class="elv-header-version">v{{ npmVersions.latest }}</code></a></li> #}
			<li>
				<details-utils close-click-outside close-esc>
					<details class="elv-popover">
						<summary>Versions</summary>
						<div>
							<ul class="list-bare">
								<li><a href="/docs/"><code>v4</code> <small>Pre-release</small></a></li>
								<li><a href="https://www.11ty.dev/docs/" class="elv-externalexempt"><code>v3</code> <small>Stable</small></a></li>
								<li><a href="https://v2.11ty.dev/docs/" class="elv-externalexempt"><code>v2</code></a></li>
								<li><a href="https://v1.11ty.dev/docs/" class="elv-externalexempt"><code>v1</code></a></li>
								<li><a href="https://v0.11ty.dev/docs/" class="elv-externalexempt"><code>v0</code></a></li>
								<li><a href="/docs/versions/">History</a></li>
								<li><a href="/firehose/">Firehose</a></li>
							</dl>
						</div>
					</details>
				</details-utils>
			</li>
			{# <li><a href="/firehose/">Firehose</a></li> #}
			{# <li><a href="https://conf.11ty.dev/" class= elv-externalexempt">Conference</a></li> #}
			{# <li><a href="https://merch.11ty.dev/products/11ty-merch-bundle-2024-limited-edition" class="elv-externalexempt">Merch</a></li> #}
			<li class="util-grow">
				<disabled-form>
					<form action="/docs/search/" class="util-stack">
						<label>
							<span class="sr-only">Search</span>
							<input type="search" name="q" placeholder="Search…" value="" disabled>
						</label>
						<button type="submit" disabled><i class="fa-solid fa-magnifying-glass"></i><span class="sr-only">Search</span></button>
					</form>
				</disabled-form>
			</li>
			{# <li class="spacer" aria-hidden="true"></li> #}
			{# <li><a href="/blog/feed.xml" class="nound elv-externalexempt elv-nav-sociallink"><i class="fa-solid fa-square-rss"></i><span class="elv-nav-sociallink-text">Feed</span></a></li> #}
			<li><a href="https://github.com/11ty/eleventy/" class="elv-skipicon"><i class="fa-brands fa-github" style="font-size: .9em"></i>GitHub</a></li>
			{# <li><a href="https://www.npmjs.com/org/11ty" class="nound elv-externalexempt elv-nav-sociallink"><i class="fa-brands fa-npm fa11ty-npm"></i><span class="sr-only">npm</span></a></li> #}
			<li><a href="https://www.youtube.com/c/EleventyVideo" class="nound elv-externalexempt elv-nav-sociallink"><i class="fa-brands fa-youtube"></i><span class="sr-only">YouTube</span></a></li>
			<li><a href="https://neighborhood.11ty.dev/@11ty" class="nound elv-nav-sociallink"><i class="fa-brands fa-mastodon"></i><span class="sr-only">Mastodon</span></a></li>
			<li><a href="https://bsky.app/profile/11ty.dev" class="nound elv-nav-sociallink"><i class="fa-brands fa-bluesky"></i><span class="sr-only">Bluesky</span></a></li>
			<li><a href="/blog/discord/" class="nound elv-nav-sociallink"><i class="fa-brands fa-discord"></i><span class="sr-only">Discord</span></a></li>
		</ul>
	</div>

	<div class="elv-nav-header">
		<is-land class="elv-possum-island" on:visible on:idle on:load on:save-data="false" on:media="(prefers-reduced-motion: no-preference)">
			<template data-island>
				<a href="/blog/awesome-possum/" class="elv-possum-anchor elv-externalexempt">
					<div class="elv-possum-pic">
						<img src="/img/mascots/awesome-possum-balloon-smile-sm.svg" alt="The possum is Eleventy’s mascot" eleventy:widths="222" class="elv-possum" loading="eager">
					</div>
				</a>
			</template>
		</is-land>
	</div>

	{% if config.outdated -%}
	{% callout "warn" %}This is an <strong>older version of Build Awesome</strong>. Go to the <a href="https://build.awesome.me/docs/">newest Eleventy docs</a> (current path: <a href="https://build.awesome.me{{ page.url }}"><code>{{ page.url }}</code></a>) or the <a href="https://build.awesome.me/docs/versions/">full release history</a>.{% endcallout %}
	{% elseif config.prerelease -%}
	{% callout "brand" %}These docs are for an upcoming version of <strong><i class="fa-brands fa-build-awesome"></i>Build Awesome</strong> — take extra care before linking here as URLs may change! Look to the <a href="https://www.11ty.dev/docs/"><i class="fa-brands fa-eleventy"></i>latest stable docs</a> instead (or the full <a href="https://build.awesome.me/docs/versions/">release history</a>).{% endcallout %}
	{% endif -%}
</header>

{% if page.url == "/" %}
{% include "components/build-awesome-hero.njk" %}
{% endif %}