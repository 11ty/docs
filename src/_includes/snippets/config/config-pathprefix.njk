{%- set tabid = "config-pathprefix" %}
<div class="codetitle codetitle-right-md">buildawesome.config.js</div>
<is-land on:visible import="/js/seven-minute-tabs.js">
<seven-minute-tabs class="tabs-flush" persist sync autoheight>
  {% renderFile "./src/_includes/syntax-chooser-tablist.11ty.js", {id: tabid, only: "jsesm,jscjs"} %}
  <div id="{{ tabid }}-jsesm" role="tabpanel">
{% set codeBlock %}
import { HtmlBasePlugin } from "@awesome.me/buildawesome";

export default function ($config) {
	$config.addPlugin(HtmlBasePlugin);
};

export const config = {
	pathPrefix: "/eleventy-base-blog/",
}
{% endset %}
{{ codeBlock | highlight("js") | safe }}
  </div>
  <div id="{{ tabid }}-jscjs" role="tabpanel">
{% set codeBlock %}
const { HtmlBasePlugin } = require("@awesome.me/buildawesome");

module.exports = function ($config) {
	$config.addPlugin(HtmlBasePlugin);
};

module.exports.config = {
	pathPrefix: "/eleventy-base-blog/",
}
{% endset %}
{{ codeBlock | highlight("js") | safe }}
  </div>
</seven-minute-tabs>
</is-land>